# ==========================================
# DATABASE CONFIGURATIONS
# ==========================================
# For local development without Docker, you can uncomment SQLite:
# DATABASE_URL=sqlite:///./inventory.db

# For Docker / Production setup (PostgreSQL):
DATABASE_URL=postgresql://postgres:postgres_secure_pass@db:5432/inventory
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_secure_pass
POSTGRES_DB=inventory


# ==========================================
# FRONTEND CONFIGURATIONS
# ==========================================
# Points to the backend API.
# Note: Because the compiled React bundle executes in the client browser,
# this should point to your public-facing URL (or localhost:8000 for local runs).
VITE_API_URL=http://localhost:8000
